{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "module": "esnext",
    "types": ["svelte", "vite/client"],
    "noEmit": true,
    "allowJs": true,
    "checkJs": true,
    "moduleDetection": "force",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "$lib": ["src/lib"],
      "$lib/*": ["src/lib/*"],
      "$engine": ["src/engine"],
      "$engine/*": ["src/engine/*"],
      "$routes": ["src/routes"],
      "$routes/*": ["src/routes/*"],
      "$storage": ["src/storage"],
      "$storage/*": ["src/storage/*"],
      "$state": ["src/state"],
      "$state/*": ["src/state/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.js", "src/**/*.svelte"]
}
